{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".gitignore",
      ".gitattributes",
      ".firebase/**",
      ".agents/**",
      ".claude/**",
      "skills-lock",
      "README.md",
      "node_modules/**",
      ".git/**"
    ],
    "cleanUrls": false,
    "trailingSlash": false,
    "rewrites": [
      { "source": "/",                   "destination": "/boomhaus-homepage.html" },
      { "source": "/home",               "destination": "/boomhaus-homepage.html" },
      { "source": "/about",              "destination": "/boomhaus-about.html" },
      { "source": "/hospitality",        "destination": "/boomhaus-hospitality.html" },
      { "source": "/residential",        "destination": "/boomhaus-residential.html" },
      { "source": "/furniture-packs",    "destination": "/boomhaus-furniture-packs.html" },
      { "source": "/superhost-audit",    "destination": "/boomhaus-superhost-v2.html" },
      { "source": "/superhost",          "destination": "/boomhaus-superhost-v2.html" },
      { "source": "/contact",            "destination": "/boomhaus-contact.html" },
      { "source": "/order/**",           "destination": "/boomhaus-order.html" },
      { "source": "/the-blakethrough",   "destination": "/boomhaus-the-blakethrough.html" },
      { "source": "/the-btr",            "destination": "/boomhaus-the-btr.html" },
      { "source": "/the-classic",        "destination": "/boomhaus-the-classic.html" },
      { "source": "/the-lois",           "destination": "/boomhaus-the-lois.html" },
      { "source": "/the-take-five",      "destination": "/boomhaus-the-take-five.html" },
      { "source": "/privacy-policy",        "destination": "/boomhaus-privacy-policy.html" },
      { "source": "/terms",                  "destination": "/boomhaus-terms.html" },
      { "source": "/thank-you/order",            "destination": "/boomhaus-thank-you-order.html" },
      { "source": "/thank-you/enquiry",           "destination": "/boomhaus-thank-you-enquiry.html" },
      { "source": "/thank-you/audit",             "destination": "/boomhaus-thank-you-audit.html" },
      { "source": "/airbnb-host",                 "destination": "/boomhaus-airbnb-host.html" },
      { "source": "/boomhaus-airbnb-host",        "destination": "/boomhaus-airbnb-host.html" },
      { "source": "/btr",                         "destination": "/boomhaus-btr.html" },
      { "source": "/london-interior-designer",    "destination": "/boomhaus-london-interior-designer.html" },
      { "source": "/the-blakethrough/gallery",   "destination": "/boomhaus-the-blakethrough-gallery.html" },
      { "source": "/the-lois/gallery",          "destination": "/boomhaus-the-lois-gallery.html" },
      { "source": "/the-classic/gallery",       "destination": "/boomhaus-the-classic-gallery.html" },
      { "source": "/the-btr/gallery",           "destination": "/boomhaus-the-btr-gallery.html" },
      { "source": "/the-take-five/gallery",     "destination": "/boomhaus-the-take-five-gallery.html" }
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
          { "key": "X-Content-Type-Options",  "value": "nosniff" },
          { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|png|gif|webp|svg|mp4|webm|ico|tif|tiff)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
        ]
      },
      {
        "source": "**/*.@(css|js)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=604800" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600" }
        ]
      }
    ],
    "errorPage": "/404.html"
  }
}
